# ============================================
# Environment Variables Configuration
# ============================================
# This is a sample .env file based on the actual project structure
# Copy this file to .env in the root directory and fill in your actual values
# DO NOT commit .env to version control
# ============================================

# ============================================
# Debug & Environment
# ============================================
DEBUG=true
ENV=development

# ============================================
# Database Configuration
# ============================================
MONGO_URL=mongodb://localhost:27017/
DATABASE=your_database_name

# ============================================
# Server Configuration
# ============================================
PORT=3000
MAX_EXECUTION_TIME=300000
URL=http://localhost
HOST_URL=http://localhost
SOCKET_URL=http://localhost
HOST_PORT=3000
SERVER_IP=127.0.0.1

# ============================================
# Timezone Configuration
# ============================================
TZ=Asia/Kuwait

# ============================================
# Google API Configuration
# ============================================
GOOGLE_API_KEY=your_google_maps_api_key_here
GOOGLE_AUTO_COMPLETE_API_KEY=your_google_autocomplete_api_key_here
DISTANCE_GOOGLE_API=your_google_distance_api_key_here
PLACES_GOOGLE_API=your_google_places_api_key_here
DIRECTION_GOOGLE_API=your_google_direction_api_key_here

# ============================================
# Push Notifications
# ============================================
ANDROID_SERVER_KEY=your_fcm_android_server_key_here
API_HEADER_AUTH_KEY=your_api_authentication_key_here

# ============================================
# Socket.IO Configuration
# ============================================
SOCKET_ENABLE=false

# ============================================
# Email Configuration
# ============================================
SMTP_AUTH=false
# Note: SMTP host, port, username, password are stored in database settings collection

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_TO_SERVER=false
UPLOAD_SERVER_URL=http://your-upload-server.com/

# ============================================
# System Settings
# ============================================
COPY_SYSTEM_SETTINGS=false

# ============================================
# Cron Jobs Configuration
# ============================================
CRON_SERVER_URL=http://localhost:3000

# ============================================
# KFG Integration
# ============================================
KFG_SOAP_API_URL=https://api-url.com/KFGWebService.svc?singleWsdl
KFG_SOAP_LICENCE_KEY=your_aghzeya_passcode_here

# ============================================
# Notes
# ============================================
# 1. Replace all 'your_*_here' values with actual credentials
# 2. Never commit .env file to version control
# 3. Use different .env files for different environments (dev/staging/prod)
# 4. Some settings (email, SMS) are stored in database, not in .env
# 5. Ensure MongoDB is running before starting the application
# 6. Google API keys can be obtained from Google Cloud Console
# 7. KFG credentials are provided by the KFG system administrator
# 8. For production, set ENV=production and DEBUG=false
